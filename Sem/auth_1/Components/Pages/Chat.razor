@page "/chat"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IChatService ChatService
@inject ChatNotificationService NotificationService
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject IServiceProvider ServiceProvider
@implements IDisposable

<PageTitle>Chat</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Users</h5>
                </div>
                <div class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                    @if (users != null)
                    {
                        @foreach (var user in users.Where(u => u.Id != currentUserId))
                        {
                            var unreadCount = unreadCounts?.GetValueOrDefault(user.Id) ?? 0;
                            <button @onclick="() => SelectUser(user)" 
                                    class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(selectedUser?.Id == user.Id ? "active" : "")">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(user.Avatar))
                                    {
                                        <img src="@user.Avatar" class="rounded-circle me-2" style="width: 30px; height: 30px; object-fit: cover;" alt="Avatar" />
                                    }
                                    else
                                    {
                                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 30px; height: 30px; font-size: 0.8rem;">
                                            @user.UserName?.FirstOrDefault()
                                        </div>
                                    }
                                    <span>@user.UserName</span>
                                </div>
                                @if (unreadCount > 0)
                                {
                                    <span class="badge bg-danger rounded-pill">@unreadCount</span>
                                }
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm" style="height: 500px;">
                <div class="card-header bg-primary text-white d-flex align-items-center">
                    @if (selectedUser != null)
                    {
                        @if (!string.IsNullOrEmpty(selectedUser.Avatar))
                        {
                            <img src="@selectedUser.Avatar" class="rounded-circle me-2" style="width: 35px; height: 35px; object-fit: cover;" alt="Avatar" />
                        }
                        else
                        {
                            <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px; font-size: 1rem; font-weight: bold;">
                                @selectedUser.UserName?.FirstOrDefault()
                            </div>
                        }
                        <h5 class="mb-0">Chat with @selectedUser.UserName</h5>
                    }
                    else
                    {
                        <h5 class="mb-0">Select a user to start chatting</h5>
                    }
                </div>
                <div class="card-body overflow-auto d-flex flex-column" id="messageList">
                    @if (messages != null)
                    {
                        @foreach (var msg in messages)
                        {
                            var isMe = msg.SenderId == currentUserId;
                            <div class="mb-2 d-flex @(isMe ? "justify-content-end" : "justify-content-start")">
                                @if (!isMe)
                                {
                                    @if (!string.IsNullOrEmpty(selectedUser?.Avatar))
                                    {
                                        <img src="@selectedUser.Avatar" class="rounded-circle me-2 mt-auto" style="width: 25px; height: 25px; object-fit: cover;" alt="Avatar" />
                                    }
                                    else
                                    {
                                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2 mt-auto" style="width: 25px; height: 25px; font-size: 0.6rem;">
                                            @selectedUser?.UserName?.FirstOrDefault()
                                        </div>
                                    }
                                }
                                <div class="p-2 rounded @(isMe ? "bg-primary text-white" : "bg-light")" style="max-width: 75%;">
                                    <div>@msg.Message</div>
                                    <div class="smaller @(isMe ? "text-white-50" : "text-muted")">@msg.Timestamp.ToLocalTime().ToString("t")</div>
                                </div>
                            </div>
                        }
                    }
                </div>
                @if (selectedUser != null)
                {
                    <div class="card-footer">
                        <div class="input-group">
                            <input @bind="newMessage" @bind:event="oninput" @onkeyup="HandleKeyUp" 
                                   class="form-control" placeholder="Type a message..." />
                            <button class="btn btn-primary" @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(newMessage))">Send</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    #messageList {
        flex-grow: 1;
    }
    .smaller {
        font-size: 0.75rem;
    }
</style>

@code {
    private List<ApplicationUser>? users;
    private ApplicationUser? selectedUser;
    private List<ChatMessage>? messages;
    private Dictionary<string, int>? unreadCounts;
    private string? currentUserId;
    private string? newMessage;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var authState = await AuthState;
            var user = authState.User;
            var currentUser = await UserManager.GetUserAsync(user);
            currentUserId = currentUser?.Id;
            
            if (currentUserId != null)
            {
                // Only show friends in the chat list
                var friendService = ServiceProvider.GetRequiredService<IFriendService>();
                users = await friendService.GetFriendsAsync(currentUserId);
                unreadCounts = await ChatService.GetUnreadCountsAsync(currentUserId);
            }
        }

        NotificationService.OnMessageReceived += HandleMessageReceived;
    }

    private async void HandleMessageReceived(string receiverId, string senderId)
    {
        if (receiverId == currentUserId)
        {
            await InvokeAsync(async () =>
            {
                if (selectedUser != null && senderId == selectedUser.Id)
                {
                    await ChatService.MarkAsReadAsync(currentUserId, senderId);
                    await LoadChatHistory();
                }
                else
                {
                    unreadCounts = await ChatService.GetUnreadCountsAsync(currentUserId);
                }
                StateHasChanged();
            });
        }
    }

    private async Task SelectUser(ApplicationUser user)
    {
        selectedUser = user;
        if (currentUserId != null)
        {
            await ChatService.MarkAsReadAsync(currentUserId, user.Id);
            unreadCounts = await ChatService.GetUnreadCountsAsync(currentUserId);
        }
        await LoadChatHistory();
    }

    private async Task LoadChatHistory()
    {
        if (selectedUser != null && currentUserId != null)
        {
            messages = await ChatService.GetChatHistoryAsync(currentUserId, selectedUser.Id);
        }
    }

    private async Task SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(newMessage) && selectedUser != null && currentUserId != null)
        {
            var chatMsg = new ChatMessage
            {
                SenderId = currentUserId,
                ReceiverId = selectedUser.Id,
                Message = newMessage,
                Timestamp = DateTime.UtcNow
            };

            await ChatService.SaveMessageAsync(chatMsg);
            
            // Notify other sessions via the singleton service
            NotificationService.NotifyMessage(selectedUser.Id, currentUserId);

            newMessage = string.Empty;
            await LoadChatHistory();
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    public void Dispose()
    {
        NotificationService.OnMessageReceived -= HandleMessageReceived;
    }
}
