@using Messenger.Models


<div class="border-bottom mb-3 pb-2">
    <h5 class="mb-0">Friends</h5>
</div>

@if (Friends == null || Friends.Count == 0)
{
    <div class="text-muted fst-italic small">
        No friends yet — search for users to add some.
    </div>
}
else
{
    <div class="d-flex flex-column gap-1">
        @foreach (var friend in Friends)
        {
            <div class="d-flex align-items-center gap-2 px-2 py-2 rounded-3 hover-row">
                <img src="@friend.Avatar" class="user-avatar" alt="Avatar" />
                <span class="fw-medium">@friend.UserName</span>
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<User>? Friends { get; set; }
}