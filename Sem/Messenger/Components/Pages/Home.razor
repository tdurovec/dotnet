@page "/"

@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Home</PageTitle>

<AuthorizeView>
    <NotAuthorized>
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8">

                    <div class="card shadow-sm">
                        <div class="card-body p-4">

                            <h2 class="mb-3">Welcome to MyApp</h2>

                            <p class="lead">
                                MyApp is a simple social platform where you can find people,
                                send friend requests and manage your connections.
                            </p>

                            <hr />

                            <div class="row mb-4">
                                <div class="col-md-4">
                                    <h6>🔎 Find people</h6>
                                    <p class="small text-muted">
                                        Search users by username and discover new connections.
                                    </p>
                                </div>

                                <div class="col-md-4">
                                    <h6>🤝 Connect</h6>
                                    <p class="small text-muted">
                                        Send and receive friend requests securely.
                                    </p>
                                </div>


                        </div>
                    </div>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>