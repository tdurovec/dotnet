@using Microsoft.AspNetCore.Components.Authorization

<nav class="navbar navbar-expand-lg navbar-dark bg-dark py-1">
    <div class="container-fluid">
        <NavLink class="navbar-brand fw-semibold" href="/">
            ChatApp
        </NavLink>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav ms-auto align-items-lg-center">
                <AuthorizeView>
                    <Authorized>
                        <UserMenu />
                    </Authorized>

                    <NotAuthorized>
                        <li class="nav-item me-2">
                            <NavLink class="btn btn-secondary btn-sm" href="/account/login">
                                Login
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="btn btn-secondary btn-sm" href="/account/register">
                                Register
                            </NavLink>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>